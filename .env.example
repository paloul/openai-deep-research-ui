# Server Config UI (set to true to enable server config management via Web UI)
ENABLE_CONFIG_UI=false
# Generate a strong value before enabling the config UI.
CONFIG_ADMIN_PASSWORD=

# Simple app login
ODR_AUTH_ENABLED=true
ODR_AUTH_USERNAME=admin
# Required when auth is enabled. Example generator:
#   openssl rand -hex 32
ODR_AUTH_PASSWORD=
ODR_SESSION_SECRET=
# Set true when serving over HTTPS.
ODR_COOKIE_SECURE=false
# Optional comma-separated allowlist for browser clients on different origins.
# Leave empty for same-origin only.
ODR_CORS_ORIGINS=
# Failed-login throttle: max attempts per IP+username within the window.
ODR_LOGIN_MAX_FAILURES=5
ODR_LOGIN_FAILURE_WINDOW_SECONDS=300
ODR_LOGIN_MAX_BODY_BYTES=4096
ODR_LOGIN_MAX_USERNAME_LENGTH=256
ODR_LOGIN_MAX_PASSWORD_LENGTH=512

# API key fallback. You can also set this in odr-config.json under model.providers.
# OPENAI_API_KEY=your_openai_api_key_here

# Logging
DEBUG=False
LOG_LEVEL=INFO
