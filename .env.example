# Server Config UI (set to true to enable server config management via Web UI)
ENABLE_CONFIG_UI=false
CONFIG_ADMIN_PASSWORD=change_me_to_a_secure_password

# Simple app login
ODR_AUTH_ENABLED=true
ODR_AUTH_USERNAME=admin
ODR_AUTH_PASSWORD=change_me_to_a_secure_password
ODR_SESSION_SECRET=change_me_to_a_long_random_secret
# Set true when serving over HTTPS.
ODR_COOKIE_SECURE=false

# API key fallback. You can also set this in odr-config.json under model.providers.
# OPENAI_API_KEY=your_openai_api_key_here

# Logging
DEBUG=False
LOG_LEVEL=INFO
